{
  "version": "1",
  "services": [
    {
      "name": "ceam-postgres",
      "type": "database",
      "image": "postgres:16-alpine",
      "environment": {
        "POSTGRES_USER": "ceam",
        "POSTGRES_PASSWORD": "${POSTGRES_PASSWORD}",
        "POSTGRES_DB": "ceam_db"
      },
      "volumes": ["pgdata:/var/lib/postgresql/data"],
      "healthcheck": {
        "test": "pg_isready -U ceam -d ceam_db",
        "interval": "10s",
        "timeout": "5s",
        "retries": 5
      }
    },
    {
      "name": "ceam-backend",
      "type": "application",
      "buildPath": "./backend",
      "dockerfile": "Dockerfile",
      "environment": {
        "DATABASE_URL": "postgresql://ceam:${POSTGRES_PASSWORD}@ceam-postgres:5432/ceam_db?sslmode=disable",
        "SECRET_KEY": "${SECRET_KEY}",
        "N8N_WEBHOOK_URL": "${N8N_WEBHOOK_URL}",
        "CEAM_DATA_URL": "${CEAM_DATA_URL}",
        "CORS_ORIGINS": "${CORS_ORIGINS}",
        "ENVIRONMENT": "production",
        "PORT": "8080"
      },
      "ports": ["8080:8080"],
      "dependsOn": ["ceam-postgres"]
    },
    {
      "name": "ceam-frontend",
      "type": "application",
      "buildPath": "./frontend",
      "dockerfile": "Dockerfile",
      "environment": {
        "NEXTAUTH_SECRET": "${NEXTAUTH_SECRET}",
        "NEXTAUTH_URL": "${NEXTAUTH_URL}",
        "NEXT_PUBLIC_API_URL": "http://ceam-backend:8080"
      },
      "ports": ["3000:3000"],
      "dependsOn": ["ceam-backend"]
    }
  ],
  "networks": ["ceam-network"]
}
